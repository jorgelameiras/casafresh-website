{
  "name": "dayoff-website",
  "version": "1.0.0",
  "description": "DayOff AC & Heating Solutions — website",
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "sass src/styles/main.scss dist/main.css --style=compressed --no-source-map",
    "build:js": "esbuild src/main.ts --bundle --minify --outfile=dist/main.js",
    "watch": "concurrently \"sass --watch src/styles/main.scss dist/main.css\" \"esbuild src/main.ts --bundle --outfile=dist/main.js --watch\"",
    "dev": "npm run build && npx serve . -p 3001"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "sass": "^1.83.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.7.0"
  }
}
